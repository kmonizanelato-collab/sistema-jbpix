# Copie este arquivo para .env.local e preencha.

# Neon (https://neon.tech) — crie um projeto e cole a connection string.
# Use a mesma em desenvolvimento e em produção enquanto for só a loja.
DATABASE_URL="postgresql://usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Chave que assina o cookie de sessão. Mínimo 32 caracteres.
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=""

# Vercel Blob — onde ficam as artes.
# Na Vercel: Storage > Blob > criar, que a variável entra sozinha no projeto.
# Local: copie o token do painel da Vercel.
BLOB_READ_WRITE_TOKEN=""

# Senhas iniciais criadas pelo npm run db:setup.
# Se deixar em branco, o script sorteia uma e mostra no terminal uma unica vez.
# Usuarios ja existentes nunca tem a senha sobrescrita.
SEED_ADMIN_PASSWORD=""
SEED_THAIS_PASSWORD=""
